APP_ENV=prod
APP_TIMEZONE=Asia/Shanghai
APP_LANGUAGE_MODE=zh_with_en_terms

# Railway-first template. For local smoke testing, replace hosts with localhost/dev values.
ASSISTANT_DB_URL=postgresql+asyncpg://postgres:postgres@assistant-db.railway.internal:5432/assistant

TEMPORAL_HOST=temporal.railway.internal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE_INGEST=ingest
TEMPORAL_TASK_QUEUE_PROCESS=process
TEMPORAL_TASK_QUEUE_VERIFY=verify
TEMPORAL_TASK_QUEUE_PUSH=push
TEMPORAL_TASK_QUEUE_DIGEST=digest
TEMPORAL_TASK_QUEUE_DEEPDIVE=deepdive

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL_SUMMARY=deepseek-chat
LLM_MODEL_SCORE=deepseek-chat
LLM_MODEL_VERIFY=deepseek-reasoner
LLM_MODEL_CHAT=deepseek-chat

TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com

MINIFLUX_BASE_URL=https://your-miniflux.up.railway.app
MINIFLUX_API_TOKEN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=replace-with-long-random-string
TELEGRAM_TARGET_CHAT_ID=
TELEGRAM_ADMIN_USER_IDS=123456789

A_PUSH_LIMIT_PER_DAY=10
PUSH_WINDOW_HOURS=24
MINIFLUX_SCAN_LIMIT=200
INGEST_ACTIONABLE_LIMIT=15
RATE_LIMIT_USER_QPM=6
RATE_LIMIT_CHAT_QPM=60
RATE_LIMIT_DEEPDIVE_PER_DAY=5
MONTHLY_BUDGET_USD=200

INTERNAL_API_TOKEN=replace-with-long-random-string
